{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "FormatterName": "pipe",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss | ",
        "UseUtcTimestamp": false,
        "SingleLine": true
      }
    }
  },
  "DoorWatch": {
    "FrameIntervalMs": 1000,
    "Camera": {
      "Source": "Rtsp",
      "DeviceIndex": 0,
      "RtspUrl": ""
    },
    "Detector": {
      "Method": "EdgeBased",
      "Roi": {
        "X": 932,
        "Y": 80,
        "Width": 900,
        "Height": 250
      },
      "ChangeThresholdPercent": 60.0,
      "EdgeChangeThresholdPercent": 18.0,
      "EdgeCloseThresholdPercent": 10.0,
      "NightSaturationThreshold": 10.0,
      "DebounceFrames": 3,
      "BaselineImagePath": "/data/baseline.png"
    },
    "HomeAssistant": {
      "BaseUrl": "http://homeassistant-ip:8123",
      "Token": "",
      "EntityId": "input_boolean.detected_door_state"
    }
  }
}
